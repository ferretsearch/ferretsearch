# Slack connector
SLACK_BOT_TOKEN="xoxb-your-bot-token-here"
SLACK_CHANNELS="C123456789,C123456789"   # comma-separated channel IDs
SLACK_SYNC_HISTORY_DAYS=7

# GitHub connector
GITHUB_TOKEN="ghp_your_token_here"
GITHUB_REPOS="owner/repo1,owner/repo2"
GITHUB_INDEX_README=true
GITHUB_INDEX_ISSUES=true
GITHUB_INDEX_PRS=true
GITHUB_INDEX_WIKI=true
GITHUB_INDEX_CODE=false                        # opt-in required
GITHUB_CODE_EXTENSIONS=.ts,.js,.py,.go,.java
GITHUB_SYNC_INTERVAL_MINUTES=60

# Google Drive connector
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_IDS=id1,id2                   # comma-separated folder IDs to index
GOOGLE_INDEX_DOCS=true
GOOGLE_INDEX_SHEETS=true
GOOGLE_INDEX_SLIDES=true
GOOGLE_INDEX_FILES=true                            # pdf, docx, txt, md
GOOGLE_SYNC_INTERVAL_MINUTES=60

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Ollama
OLLAMA_URL=http://localhost:11434

# API server
API_PORT=3000
WORKER_CONCURRENCY=5
