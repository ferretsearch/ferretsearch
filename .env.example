# CapyTrace Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3000
UI_PORT=5173
WORKER_CONCURRENCY=5

# ── Slack Connector ───────────────────────────────────────────────────────────
# Create an app at: https://api.slack.com/apps
# Required OAuth scopes: channels:read, channels:history, files:read, users:read
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNELS=C0123456789,C9876543210
# SLACK_SYNC_HISTORY_DAYS=30
# SLACK_SYNC_INTERVAL_MINUTES=60

# ── GitHub Connector ──────────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens (classic)
# Required scopes: repo, read:user
# GITHUB_TOKEN=ghp_...
# GITHUB_REPOS=owner/repo1,owner/repo2
# GITHUB_INDEX_README=true
# GITHUB_INDEX_ISSUES=true
# GITHUB_INDEX_PRS=true
# GITHUB_INDEX_WIKI=true
# GITHUB_INDEX_CODE=false
# GITHUB_CODE_EXTENSIONS=.ts,.js,.py,.go,.java,.md
# GITHUB_SYNC_INTERVAL_MINUTES=60

# ── Google Drive Connector ────────────────────────────────────────────────────
# Create a service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Share your Drive folders with the service account email address
# GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
# GOOGLE_DRIVE_FOLDER_IDS=your_folder_id_here
# GOOGLE_INDEX_DOCS=true
# GOOGLE_INDEX_SHEETS=true
# GOOGLE_INDEX_SLIDES=true
# GOOGLE_INDEX_FILES=true
# GOOGLE_SYNC_INTERVAL_MINUTES=60
